        <mxCell id="NrktPaHlzSkP6euk4Bus-14" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="怪物ai由服务器下推攻击，野怪由客户端控制攻击" vertex="1">
