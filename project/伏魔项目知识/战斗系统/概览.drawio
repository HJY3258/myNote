            <mxPoint x="933" y="2020" as="sourcePoint" />
            <mxPoint x="930" y="1980" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="iuiQEy3bBR2bTAC2Q6AM-2" parent="1" style="swimlane;childLayout=stackLayout;horizontal=1;startSize=50;horizontalStack=0;rounded=1;fontSize=14;fontStyle=0;strokeWidth=2;resizeParent=0;resizeLast=1;shadow=0;dashed=0;align=center;arcSize=4;whiteSpace=wrap;html=1;" value="KillStageBoss&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;FightProcess&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="120" x="1120" y="1830" as="geometry" />
        </mxCell>
        <mxCell id="iuiQEy3bBR2bTAC2Q6AM-3" parent="iuiQEy3bBR2bTAC2Q6AM-2" style="align=left;strokeColor=none;fillColor=none;spacingLeft=4;spacingRight=4;fontSize=12;verticalAlign=top;resizable=0;rotatable=0;part=1;html=1;whiteSpace=wrap;" value="+闯关击杀目标&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;+分镜结束后寻找最近敌人，优先boss，有挂机点去挂机点，没有就原地罚站&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="120" y="50" as="geometry" />
        </mxCell>
